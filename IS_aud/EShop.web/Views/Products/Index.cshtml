@model List<EShop.Domain.DomainModels.Product>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container">

    <div class="btn">
        <a class="btn btn-success" asp-action="Create">Insert New Product</a>
    </div>

    @foreach(var item in Model)
    {
        
        @if(Model.Count == 3)
        {
            @:<div class="row">
        }

                <div class="col-lg-4 m-2">

                    <div class="card" style="width: 20rem; height: 30rem;">
                        <img class="card-img-top" src="@item.ImageURL" style="width: auto" alt="Image for product!">

                        <div class="card-body">
                            <h3 class="card-title">@item.Name</h3>
                            <p class="card-text">@item.Description</p>


                            <h6>Price: @item.Price ДЕН</h6>
                        </div>

                        <div class="card-footer">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info">Edit</a> 
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary">Details</a> 
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                        </div>
                    </div>

                </div>

        @if(Model.Count % 3 == 2) 
        {
            @:</div>    
        }
    }
</div>